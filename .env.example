# Strapi REST base URL (no trailing slash). Required for layout data and page blocks.
# Example local: http://localhost:1337
PUBLIC_STRAPI_URL=

# Public site URL (no trailing slash). Required for absolute Open Graph URLs in prerendered HTML.
# Example production: https://www.geko-berlin.de
PUBLIC_SITE_URL=

# API token for Strapi Content API (/api/*). Server-only — do not use PUBLIC_ prefix.
# Required when "Public" REST access is disabled in Strapi.
STRAPI_AUTH_TOKEN=

# Set to true to relax prerender cache while building previews (optional).
# PUBLIC_PREVIEW_MODE=
